targets:
  - name: Desktop
    host: 192.168.1.10  # host: <your-streaming-host-ip>
    app: Desktop
    resolution: 3840x2160
    fps: 120
    codec: HEVC
    hdr: true
    # Optional: Sunshine API credentials for session detection.
    # When present, the shell checks for active sessions before launching
    # and offers Resume / Quit & Relaunch if a different app is running.
    # sunshineUser: admin
    # sunshinePass: your-password
    # sunshinePort: 47990  # default if omitted
